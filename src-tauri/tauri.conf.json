{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eDEX-UI",
  "version": "3.0.0",
  "identifier": "dev.edex.ui",
  "build": {
    "frontendDist": "../src",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "eDEX-UI",
        "width": 1920,
        "height": 1200,
        "minWidth": 800,
        "minHeight": 500,
        "fullscreen": false,
        "decorations": true,
        "resizable": true,
        "backgroundColor": "#000000",
        "url": "ui.html"
      }
    ],
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' tauri: asset: 'unsafe-inline' 'unsafe-eval'; img-src 'self' tauri: asset: data:; media-src 'self' tauri: asset: data:; font-src 'self' tauri: asset: data:; connect-src ipc: http://ipc.localhost asset: https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "eDEX-UI sci-fi terminal",
    "longDescription": "A sci-fi terminal emulator with system monitoring panels, ported to native Apple Silicon via Tauri.",
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": []
    }
  }
}
